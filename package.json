{
  "name": "about-site",
  "version": "2.0.0",
  "description": "Личный сайт-портфолио Alex Melan",
  "private": true,
  "scripts": {
    "build:html": "node build.js",
    "build:css": "tailwindcss -i src/input.css -o assets/css/site.css --minify",
    "build": "node build.js && tailwindcss -i src/input.css -o assets/css/site.css --minify",
    "watch:css": "tailwindcss -i src/input.css -o assets/css/site.css --watch",
    "dev": "node build.js && tailwindcss -i src/input.css -o assets/css/site.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
